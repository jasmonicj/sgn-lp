---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ナビ -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
      <span class="text-lg font-bold text-gray-800 tracking-tight">Social Good Natives</span>
      <nav class="hidden sm:flex items-center gap-6 text-sm text-gray-600">
        <a href="#about" class="hover:text-amber-600 transition-colors">About</a>
        <a href="#services" class="hover:text-amber-600 transition-colors">Services</a>
        <a href="#members" class="hover:text-amber-600 transition-colors">Members</a>
        <a href="#join" class="hover:text-amber-600 transition-colors">Join</a>
      </nav>
      <a
        href="#contact"
        class="text-sm bg-amber-500 text-white px-4 py-1.5 rounded-full font-medium hover:bg-amber-600 transition-colors"
      >
        お問い合わせ
      </a>
    </div>
  </header>

  <main class="pt-14">

    <!-- ── Hero ────────────────────────────────────────────────── -->
    <section
      aria-labelledby="hero-heading"
      class="min-h-[90vh] flex flex-col items-center justify-center text-center px-4 bg-gradient-to-b from-amber-50 to-white"
    >
      <p class="text-sm tracking-widest text-amber-600 mb-4 uppercase font-medium">General Incorporated Association</p>
      <h1
        id="hero-heading"
        class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-800 leading-tight mb-4"
      >
        ソーシャルグッドを、<br class="sm:hidden" />あたりまえに。
      </h1>
      <p class="text-lg sm:text-xl text-gray-500 mb-2 max-w-lg">
        サステナブル・エシカルな社会をリードする<br />デジタルネイティブ世代のコミュニティ。
      </p>
      <p class="text-base text-gray-400 mb-10 max-w-md">
        企業と個人をつなぎ、社会をよくする「問い」を共創する。
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#join"
          class="bg-amber-500 text-white text-lg font-bold px-8 py-4 rounded-full shadow-lg hover:bg-amber-600 transition-all hover:scale-105 active:scale-95"
        >
          メンバーになる
        </a>
        <a
          href="#contact"
          class="bg-white text-amber-600 text-lg font-bold px-8 py-4 rounded-full shadow-lg border-2 border-amber-500 hover:bg-amber-50 transition-all hover:scale-105 active:scale-95"
        >
          企業の方はこちら
        </a>
      </div>

      <!-- スクロールヒント -->
      <div class="mt-16 animate-bounce text-gray-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </section>

    <!-- ── About ──────────────────────────────────────────────── -->
    <section id="about" aria-labelledby="about-heading" class="py-20 bg-white px-4">
      <div class="max-w-3xl mx-auto">
        <p class="text-sm text-amber-600 font-bold tracking-widest uppercase mb-2 text-center">About</p>
        <h2 id="about-heading" class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-6">
          Social Good Natives とは
        </h2>
        <p class="text-gray-500 text-base sm:text-lg leading-relaxed text-center mb-12">
          Social Good Natives（SGNs）は、<strong class="text-gray-700">「ソーシャルグッド」を当然の価値観とするデジタルネイティブ世代</strong>を中心としたコミュニティ・エージェントです。<br /><br />
          エシカルファッション、フードロス、若者のエンパワメントなど多岐にわたるテーマで活動・発信する個人やユニットが在籍し、<strong class="text-emerald-600">企業やメディアに対してソーシャルグッド軸での「問い」を提供</strong>しています。
        </p>

        <!-- ミッション・ビジョン -->
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-emerald-50 rounded-2xl p-8 text-center">
            <p class="text-xs text-emerald-600 font-bold tracking-widest uppercase mb-3">Mission</p>
            <p class="text-gray-700 font-bold text-lg leading-relaxed">
              ソーシャルグッドな概念から<br />社会を再解釈し、<br />世代を超えて共創する。
            </p>
          </div>
          <div class="bg-emerald-50 rounded-2xl p-8 text-center">
            <p class="text-xs text-emerald-600 font-bold tracking-widest uppercase mb-3">Vision</p>
            <p class="text-gray-700 font-bold text-lg leading-relaxed">
              サステナブル・エシカルが<br />「あたりまえ」になる社会を<br />次の世代とともにつくる。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 活動テーマ ──────────────────────────────────────────── -->
    <section class="py-20 bg-amber-50 px-4">
      <div class="max-w-5xl mx-auto">
        <p class="text-sm text-amber-600 font-bold tracking-widest uppercase mb-2 text-center">Activities</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-12">
          活動テーマ
        </h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">

          <article class="bg-white rounded-2xl p-6 shadow-sm text-center">
            <div class="w-14 h-14 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">エシカルファッション</h3>
            <p class="text-sm text-gray-500">ファッションの透明性を追求し、サステナブルな衣服の循環を推進</p>
          </article>

          <article class="bg-white rounded-2xl p-6 shadow-sm text-center">
            <div class="w-14 h-14 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">フードロス削減</h3>
            <p class="text-sm text-gray-500">食品廃棄の課題に取り組み、エシカルな消費文化を広める</p>
          </article>

          <article class="bg-white rounded-2xl p-6 shadow-sm text-center">
            <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">若者エンパワメント</h3>
            <p class="text-sm text-gray-500">次世代リーダーの育成と、若者の声を社会に届ける場を提供</p>
          </article>

          <article class="bg-white rounded-2xl p-6 shadow-sm text-center">
            <div class="w-14 h-14 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">SDGs推進</h3>
            <p class="text-sm text-gray-500">持続可能な開発目標の達成に向けた啓発活動と実践</p>
          </article>

        </div>
      </div>
    </section>

    <!-- ── 企業向けサービス ────────────────────────────────────── -->
    <section id="services" aria-labelledby="services-heading" class="py-20 bg-white px-4">
      <div class="max-w-5xl mx-auto">
        <p class="text-sm text-amber-600 font-bold tracking-widest uppercase mb-2 text-center">For Companies</p>
        <h2 id="services-heading" class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-4">
          企業・団体の皆さまへ
        </h2>
        <p class="text-center text-gray-500 text-sm mb-12 max-w-xl mx-auto">
          ソーシャルグッド世代の視点から、御社の事業に新しい「問い」と価値を提供します。
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

          <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">ソーシャルグッドマーケティング</h3>
            <p class="text-sm text-gray-500">Z世代・ミレニアル世代に響くサステナブル軸のマーケティング戦略を企画・実行します。</p>
          </div>

          <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">講演・登壇</h3>
            <p class="text-sm text-gray-500">ソーシャルグッド、エシカル消費、サステナビリティに関する講演・パネルディスカッションを提供します。</p>
          </div>

          <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">執筆・メディア</h3>
            <p class="text-sm text-gray-500">ソーシャルグッド視点での記事執筆、メディア共創。毎日新聞「Social Good Opinion」等の実績。</p>
          </div>

          <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">SDGs・研修プログラム</h3>
            <p class="text-sm text-gray-500">若手バディ研修、SDGsワークショップなど、社員向け研修プログラムを設計・実施します。</p>
          </div>

          <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">インフルエンサーマーケティング</h3>
            <p class="text-sm text-gray-500">ソーシャルグッド領域で影響力を持つSGNsメンバーと連携したインフルエンサー施策。</p>
          </div>

          <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            </div>
            <h3 class="font-bold text-gray-800 mb-2">共創プロジェクト</h3>
            <p class="text-sm text-gray-500">企業・団体とSGNsメンバーが協働し、ソーシャルグッドな新規プロジェクトを共創します。</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── 実績・メディア ──────────────────────────────────────── -->
    <section class="py-20 bg-gray-50 px-4">
      <div class="max-w-4xl mx-auto">
        <p class="text-sm text-amber-600 font-bold tracking-widest uppercase mb-2 text-center">Track Record</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-4">
          活動実績
        </h2>
        <p class="text-center text-gray-500 text-sm mb-12 max-w-xl mx-auto">
          2020年の設立以来、メディア・イノベーション拠点・イベントを通じてソーシャルグッドの「問い」を社会に発信し続けています。
        </p>

        <!-- メディア連携 -->
        <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-emerald-500 inline-block"></span>
          メディア連携
        </h3>
        <div class="space-y-4 mb-10">

          <a href="https://mainichi.jp/premier/politics/ch191252145i/Social+Good+Opinion" target="_blank" rel="noopener noreferrer" class="flex gap-4 items-start bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex-shrink-0 w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1 group-hover:text-amber-600 transition-colors">毎日新聞 政治プレミア「Social Good Opinion」<span class="inline-block ml-1 text-gray-400 text-xs">&nearr;</span></p>
              <p class="text-sm text-gray-500">
                SGNs発起の寄稿連載企画。毎日新聞の政治プレミアにて、Z世代のKOL（キーオピニオンリーダー）がオールドメディアのコンテンツを自身の感性で翻訳・コンテキストを付与し、世代間で同じトピックについて語り「問い」を投げかけ合える下地をつくる取り組み。
              </p>
            </div>
          </a>

          <a href="https://ideasforgood.jp/" target="_blank" rel="noopener noreferrer" class="flex gap-4 items-start bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex-shrink-0 w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1 group-hover:text-amber-600 transition-colors">IDEAS FOR GOOD ライター<span class="inline-block ml-1 text-gray-400 text-xs">&nearr;</span></p>
              <p class="text-sm text-gray-500">社会をもっとよくする世界のアイデアマガジン「IDEAS FOR GOOD」にて、SGNsメンバーが執筆活動を展開。</p>
            </div>
          </a>

        </div>

        <!-- 地域共創プロジェクト -->
        <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-emerald-500 inline-block"></span>
          地域共創プロジェクト
        </h3>
        <div class="space-y-4 mb-10">

          <a href="https://loftwork.com/jp/project/maniwa_sdgs_business" target="_blank" rel="noopener noreferrer" class="flex gap-4 items-start bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow group">
            <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1 group-hover:text-amber-600 transition-colors">岡山県真庭市 SDGsビジネスプロジェクト創出プログラム<span class="inline-block ml-1 text-gray-400 text-xs">&nearr;</span></p>
              <p class="text-sm text-gray-500">
                株式会社ロフトワーク運営のもと、SDGs未来都市・岡山県真庭市の地域事業者と都市部のビジネスパーソンがチームを組む共創プログラム「Cultivate the future maniwa（カルマニ）」に参画。松川食品株式会社とタッグを組み、Z世代の視点から老舗焼き鳥の新たな価値と可能性を探るプロジェクトを展開。報告会では共同代表の花村・小澤が登壇。
              </p>
            </div>
          </a>

        </div>

        <!-- 企業案件 -->
        <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-emerald-500 inline-block"></span>
          企業案件（一部抜粋）
        </h3>
        <div class="space-y-4 mb-10">

          <div class="flex gap-4 items-start bg-white rounded-xl p-6 shadow-sm">
            <div class="flex-shrink-0 w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center">
